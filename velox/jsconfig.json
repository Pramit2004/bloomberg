{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*":           ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@pages/*":      ["./src/pages/*"],
      "@hooks/*":      ["./src/hooks/*"],
      "@utils/*":      ["./src/utils/*"],
      "@data/*":       ["./src/data/*"],
      "@styles/*":     ["./src/styles/*"],
      "@assets/*":     ["./src/assets/*"]
    },
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "allowImportingTsExtensions": false,
    "checkJs": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
