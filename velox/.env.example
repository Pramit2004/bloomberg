# ─── VELOX Automobiles — Environment Variables ───
# Copy this file to .env and fill in your values.
# Never commit .env to git — it is in .gitignore

# ── App ──────────────────────────────────────────
# Your production domain (no trailing slash)
VITE_SITE_URL=https://velox-automobiles.com

# App name — used in SEO meta tags
VITE_APP_NAME=VELOX Automobiles

# ── Contact / Forms ──────────────────────────────
# Formspree endpoint for contact form (https://formspree.io)
VITE_FORMSPREE_ID=your_formspree_id_here

# EmailJS service/template IDs (alternative to Formspree)
# VITE_EMAILJS_SERVICE_ID=your_service_id
# VITE_EMAILJS_TEMPLATE_ID=your_template_id
# VITE_EMAILJS_PUBLIC_KEY=your_public_key

# ── Analytics ────────────────────────────────────
# Google Analytics 4 Measurement ID
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Feature Flags ────────────────────────────────
# Set to "true" to enable cookie consent banner
VITE_COOKIE_CONSENT=true

# Set to "true" to enable search modal
VITE_SEARCH_ENABLED=true
